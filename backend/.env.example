# ShopSense Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Get your FREE Groq API key at https://console.groq.com
# No credit card required — the free tier is sufficient for the full demo
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Shopify Integration ────────────────────────────────────────────────────────

# Your Shopify dev store domain (without https://)
SHOPIFY_STORE_URL=your-store.myshopify.com

# Admin API access token — get from:
# Shopify Admin → Settings → Apps and sales channels → Develop apps
# → Create an app → Configure Admin API scopes (read_products) → Install → Copy token
SHOPIFY_ADMIN_TOKEN=shpat_your_admin_api_access_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins
# For local dev: http://localhost:3000
# For production: add your Vercel frontend URL
ALLOWED_ORIGINS=http://localhost:3000
